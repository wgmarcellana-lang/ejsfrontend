<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EJS Frontend</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/styles.css?v=20260319-2" />
</head>

<body class="min-h-screen bg-[#4b1d6b] flex items-center justify-center">
  <main class="w-full max-w-5xl px-4">
    <section class="bg-white rounded-xl shadow-2xl p-8">
      <div class="mb-6">
        <h1 class="text-2xl font-semibold text-slate-900">EJS Frontend</h1>
      </div>

      <form id="basic-form" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <%- include('components/textinput') %>
          <%- include('components/dropdown') %>
          <%- include('components/calendar') %>
        </div>

        <%- include('components/buttons') %>
      </form>
    </section>

    <%- include('components/generic-modal') %>
  </main>

  <script src="/js/components/textinput.js"></script>
  <script src="/js/components/dropdown.js"></script>
  <script src="/js/components/calendar.js"></script>
  <script src="/js/components/buttons.js"></script>

  
  <script src="/js/components/generic-modal.js?v=20260319-1"></script>
  <script src="/js/main.js?v=20260319-1"></script>
</body>
</html>
